#!/bin/sh
# Cacti pre-commit hook runner.
#
# Delegates to executable scripts in .husky/pre-commit.d/*.sh, run in
# Bypass the whole hook with:  HUSKY=0 git commit ...

set -e

STAGE=pre-commit
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
D="$HOOK_DIR/$STAGE.d"

[ -d "$D" ] || exit 0

for script in "$D"/*.sh; do
	[ -e "$script" ] || continue   # no matches -> literal glob
	[ -x "$script" ] || continue   # disabled via chmod -x
	name="$(basename "$script")"
	echo "[$STAGE] >>> $name"
	"$script" "$@"
done


